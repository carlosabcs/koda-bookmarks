{
	"manifest_version": 3,
	"name": "Koda Bookmarks",
	"version": "1.0.2",
	"description": "Quickly search and save browser bookmarks.",
	"icons": {
		"16": "icon-16.png",
		"32": "icon-32.png",
		"192": "android-chrome-192.png",
		"512": "android-chrome-512.png"
	},
	"action": {
		"default_icon": {
			"16": "icon-16.png",
			"32": "icon-32.png"
		}
	},
	"permissions": ["bookmarks", "activeTab", "scripting"],
	"commands": {
		"open-koda": {
			"suggested_key": {
				"default": "Alt+Shift+K",
				"mac": "Command+Shift+K",
				"windows": "Alt+Shift+K",
				"linux": "Alt+Shift+K"
			},
			"description": "Open Koda Bookmarks browser"
		}
	},
	"background": {
		"service_worker": "src/background.ts",
		"type": "module"
	},
	"content_scripts": [{ "matches": ["<all_urls>"], "js": ["src/main.tsx"] }]
}
